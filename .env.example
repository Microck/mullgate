# Copy to .env for local development or export these variables in your shell.
# Do not commit real secrets.

# Required for non-interactive setup and live verifier runs
MULLGATE_ACCOUNT_NUMBER=123456789012
MULLGATE_PROXY_USERNAME=alice
MULLGATE_PROXY_PASSWORD=replace-me
MULLGATE_DEVICE_NAME=mullgate-local

# Common multi-route setup inputs
MULLGATE_LOCATIONS=sweden-gothenburg,austria-vienna
# MULLGATE_LOCATION=sweden-gothenburg
# MULLGATE_ROUTE_BIND_IPS=127.0.0.1,127.0.0.2
# MULLGATE_EXPOSURE_MODE=loopback
# MULLGATE_EXPOSURE_BASE_DOMAIN=proxy.example.com

# Optional bind and HTTPS settings
# MULLGATE_BIND_HOST=127.0.0.1
# MULLGATE_SOCKS_PORT=1080
# MULLGATE_HTTP_PORT=8080
# MULLGATE_HTTPS_PORT=8443
# MULLGATE_HTTPS_CERT_PATH=/absolute/path/to/proxy.crt
# MULLGATE_HTTPS_KEY_PATH=/absolute/path/to/proxy.key

# Optional Mullvad endpoint overrides
# MULLGATE_MULLVAD_WG_URL=https://api.mullvad.net/wg
# MULLGATE_MULLVAD_RELAYS_URL=https://api.mullvad.net/public/relays/wireguard/v1/

# Optional verifier overrides
# MULLGATE_VERIFY_TARGET_URL=https://am.i.mullvad.net/json
# MULLGATE_VERIFY_ROUTE_CHECK_IP=1.1.1.1
